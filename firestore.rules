rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userOwnsProfile(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function userIsParticipant() {
      return signedIn() &&
        resource.data.participants is list &&
        resource.data.participants.hasAny([request.auth.uid]);
    }

    function requestUserIsParticipant() {
      return signedIn() &&
        request.resource.data.participants is list &&
        request.resource.data.participants.hasAny([request.auth.uid]);
    }

    function validSenderIdentity() {
      return request.resource.data.senderUid == request.auth.uid &&
        request.resource.data.senderEmail == request.auth.token.email &&
        request.resource.data.senderDisplayName is string &&
        request.resource.data.text is string &&
        request.resource.data.readBy is list &&
        request.resource.data.readBy.hasOnly([request.auth.uid]);
    }

    function validReadReceiptUpdate() {
      return signedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy'])
        && request.resource.data.readBy is list
        && (!('readBy' in resource.data) || request.resource.data.readBy.hasAll(resource.data.readBy))
        && request.resource.data.readBy.hasAny([request.auth.uid]);
    }

    match /users/{uid} {
      allow read: if signedIn();
      allow create, update: if userOwnsProfile(uid)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email;
      allow delete: if false;
    }

    match /conversations/{conversationId} {
      allow read: if userIsParticipant();
      allow create: if requestUserIsParticipant();
      allow update: if userIsParticipant() && requestUserIsParticipant();
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if exists(/databases/$(database)/documents/conversations/$(conversationId))
          && get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants.hasAny([request.auth.uid]);
        allow create: if signedIn()
          && validSenderIdentity()
          && request.resource.data.participants.hasAny([request.auth.uid]);
        allow update: if validReadReceiptUpdate();
        allow delete: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
