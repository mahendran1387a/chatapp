rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownerEmail() {
      return signedIn() &&
        request.auth.token.email in ['aadhish.mahendran@gmail.com'];
    }

    function userOwnsProfile(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function approvedUid(uid) {
      return exists(/databases/$(database)/documents/users/$(uid)) &&
        get(/databases/$(database)/documents/users/$(uid)).data.approved == true;
    }

    function approvedUser(uid) {
      return signedIn() && request.auth.uid == uid && approvedUid(uid);
    }

    function hasInvitedEmail() {
      return signedIn() &&
        exists(/databases/$(database)/documents/invites/$(request.auth.token.email));
    }

    function profileKeys() {
      return [
        'uid',
        'email',
        'displayName',
        'photoURL',
        'lastLoginAt',
        'lastSeenAt',
        'onlineStatus',
        'isOnline',
        'updatedAt',
        'approved',
        'role',
        'approvedAt',
        'approvedBy'
      ];
    }

    function validProfileBasics(uid) {
      return request.resource.data.keys().hasOnly(profileKeys())
        && request.resource.data.uid == uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.displayName is string
        && request.resource.data.photoURL is string
        && request.resource.data.onlineStatus in ['online', 'away', 'offline']
        && request.resource.data.isOnline is bool;
    }

    function validSelfProfileCreate(uid) {
      return userOwnsProfile(uid)
        && validProfileBasics(uid)
        && (
          (ownerEmail() && request.resource.data.approved == true && request.resource.data.role == 'owner') ||
          (!ownerEmail() && hasInvitedEmail() && request.resource.data.approved == true && request.resource.data.role == 'member') ||
          (!ownerEmail() && request.resource.data.approved == false && request.resource.data.role == 'pending')
        );
    }

    function validSelfProfileUpdate(uid) {
      return userOwnsProfile(uid)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'displayName',
          'photoURL',
          'lastLoginAt',
          'lastSeenAt',
          'onlineStatus',
          'isOnline',
          'updatedAt'
        ])
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.onlineStatus in ['online', 'away', 'offline']
        && request.resource.data.isOnline is bool;
    }

    function validSelfInviteApproval(uid) {
      return userOwnsProfile(uid)
        && !ownerEmail()
        && hasInvitedEmail()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'displayName',
          'photoURL',
          'lastLoginAt',
          'lastSeenAt',
          'onlineStatus',
          'isOnline',
          'updatedAt',
          'approved',
          'role',
          'approvedAt',
          'approvedBy'
        ])
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.approved == true
        && request.resource.data.role == 'member'
        && request.resource.data.approvedBy is string
        && request.resource.data.onlineStatus in ['online', 'away', 'offline']
        && request.resource.data.isOnline is bool;
    }

    function validSelfPendingMigration(uid) {
      return userOwnsProfile(uid)
        && !ownerEmail()
        && !('approved' in resource.data)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'displayName',
          'photoURL',
          'lastLoginAt',
          'lastSeenAt',
          'onlineStatus',
          'isOnline',
          'updatedAt',
          'approved',
          'role'
        ])
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.approved == false
        && request.resource.data.role == 'pending'
        && request.resource.data.onlineStatus in ['online', 'away', 'offline']
        && request.resource.data.isOnline is bool;
    }

    function ownerWriteUserProfile(uid) {
      return ownerEmail()
        && request.resource.data.keys().hasOnly(profileKeys())
        && request.resource.data.uid == uid
        && request.resource.data.approved is bool
        && request.resource.data.role in ['owner', 'member', 'pending'];
    }

    function validConversationParticipants(data) {
      return approvedUser(request.auth.uid)
        && data.participants is list
        && data.participants.size() == 2
        && data.participants.hasAny([request.auth.uid])
        && approvedUid(data.participants[0])
        && approvedUid(data.participants[1]);
    }

    function validConversationCreate(data) {
      return data.keys().hasOnly(['participants', 'updatedAt'])
        && validConversationParticipants(data);
    }

    function validConversationUpdate() {
      return userIsParticipant()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['updatedAt'])
        && request.resource.data.participants == resource.data.participants;
    }

    function userIsParticipant() {
      return approvedUser(request.auth.uid)
        && resource.data.participants is list
        && resource.data.participants.hasAny([request.auth.uid]);
    }

    function validSenderIdentity() {
      return approvedUser(request.auth.uid)
        && request.resource.data.senderUid == request.auth.uid
        && request.resource.data.senderEmail == request.auth.token.email
        && request.resource.data.senderDisplayName is string
        && request.resource.data.text is string
        && request.resource.data.readBy is list
        && request.resource.data.readBy.hasOnly([request.auth.uid]);
    }

    function validReadReceiptUpdate() {
      return approvedUser(request.auth.uid)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy'])
        && request.resource.data.readBy is list
        && (!('readBy' in resource.data) || request.resource.data.readBy.hasAll(resource.data.readBy))
        && request.resource.data.readBy.hasAny([request.auth.uid]);
    }

    function validMessageConversation(conversationId) {
      return exists(/databases/$(database)/documents/conversations/$(conversationId))
        && get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants.hasAny([request.auth.uid])
        && get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants == request.resource.data.participants;
    }

    function groupHasSignedInUser(data) {
      return (data.members is list && data.members.hasAny([request.auth.uid])) ||
        (data.participants is list && data.participants.hasAny([request.auth.uid]));
    }

    function userIsGroupParticipant() {
      return approvedUser(request.auth.uid)
        && groupHasSignedInUser(resource.data);
    }

    function groupParticipant(groupId) {
      return approvedUser(request.auth.uid)
        && exists(/databases/$(database)/documents/groups/$(groupId))
        && groupHasSignedInUser(get(/databases/$(database)/documents/groups/$(groupId)).data);
    }

    function validGroupCreate() {
      return approvedUser(request.auth.uid)
        && request.resource.data.keys().hasOnly(['groupName', 'type', 'members', 'participants', 'createdBy', 'createdAt'])
        && request.resource.data.groupName is string
        && request.resource.data.type == 'group'
        && request.resource.data.members is list
        && request.resource.data.participants is list
        && request.resource.data.members.size() >= 2
        && request.resource.data.participants.size() == request.resource.data.members.size()
        && request.resource.data.members == request.resource.data.participants
        && request.resource.data.members.hasAny([request.auth.uid])
        && request.resource.data.participants.hasAny([request.auth.uid])
        && request.resource.data.createdBy == request.auth.uid;
    }

    function validGroupUpdate() {
      return false;
    }

    function validGroupMessage(groupId) {
      return validSenderIdentity() && groupParticipant(groupId);
    }

    match /users/{uid} {
      allow read: if ownerEmail() || userOwnsProfile(uid) || resource.data.approved == true;
      allow create: if validSelfProfileCreate(uid) || ownerWriteUserProfile(uid);
      allow update: if validSelfProfileUpdate(uid) || validSelfInviteApproval(uid) || validSelfPendingMigration(uid) || ownerWriteUserProfile(uid);
      allow delete: if false;
    }

    match /invites/{email} {
      allow read: if ownerEmail() || (signedIn() && email == request.auth.token.email);
      allow create, update: if ownerEmail();
      allow delete: if ownerEmail();
    }

    match /conversations/{conversationId} {
      allow read: if userIsParticipant();
      allow create: if validConversationCreate(request.resource.data);
      allow update: if validConversationUpdate();
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if approvedUser(request.auth.uid)
          && exists(/databases/$(database)/documents/conversations/$(conversationId))
          && get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants.hasAny([request.auth.uid]);
        allow create: if validSenderIdentity()
          && validMessageConversation(conversationId)
          && request.resource.data.participants.hasAny([request.auth.uid]);
        allow update: if validReadReceiptUpdate();
        allow delete: if false;
      }
    }

    match /groups/{groupId} {
      allow read: if userIsGroupParticipant();
      allow create: if validGroupCreate();
      allow update: if validGroupUpdate();
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if groupParticipant(groupId);
        allow create: if validGroupMessage(groupId);
        allow update: if groupParticipant(groupId) && validReadReceiptUpdate();
        allow delete: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
